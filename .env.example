# ─── Brains / providers ───────────────────────────────────────────────────────
# Alfred can drive four brains. Set ALFRED_PROVIDER to pick the default; an API
# brain is "enabled" only when its API key is present. Model IDs below are
# defaults you can freely adjust to whatever your account has access to.

# Default brain: anthropic | openai | deepseek
ALFRED_PROVIDER=anthropic

# 1) Anthropic API (default active brain) — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-5

# 2) OpenAI / ChatGPT API — https://platform.openai.com/
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# 3) DeepSeek API — https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_MODEL=deepseek-v4-flash

# 4) Claude Code CLI (claude -p) — the delegation brain. No key here; install the
#    CLI so it's on PATH: npm i -g @anthropic-ai/claude-code

# MCP bridge: when Alfred spawns `claude -p` (the Claude Code brain AND the
# delegate tool), it starts an in-process MCP server on 127.0.0.1 (bearer-token
# auth) and hands the CLI --mcp-config + --allowedTools so Claude Code can call
# Alfred's own tools (ui_layout, system, memory, filesystem, browser, render_ui…)
# as mcp__alfred__<tool>. Every call runs THROUGH Alfred's governance (approvals,
# trifecta, audit) — no bypass. On by default; set to 0/false/off to disable
# (claude -p then runs with only its own tools).
# ALFRED_MCP_BRIDGE=1

# Legacy alias for ANTHROPIC_MODEL (still honoured if ANTHROPIC_MODEL is unset).
ALFRED_MODEL=claude-sonnet-5

# Model the memory curator uses ("provider:model" spec). Defaults to the cheapest
# enabled brain (usually DeepSeek by price). e.g. ALFRED_CURATOR_MODEL=deepseek:deepseek-v4-flash
# ALFRED_CURATOR_MODEL=

# ─── Workspace & guardrails ─────────────────────────────────────────────────────
# Where Alfred keeps projects & memory (defaults to ~/AlfredWorkspace)
ALFRED_WORKSPACE=

# Hard daily token cap across all sessions (kill-switch)
ALFRED_DAILY_TOKEN_BUDGET=2000000

# Max tool/model steps per task (loop/runaway guard). Default 40.
# ALFRED_STEP_CAP=40

# Soft daily USD warning (ESTIMATED cost). Warns when exceeded; never blocks —
# the hard stop is always ALFRED_DAILY_TOKEN_BUDGET above. Leave unset to disable.
# ALFRED_DAILY_USD_BUDGET=5

# Optional pricing override (USD per 1M tokens). Points at a JSON file shaped like
# { "model-id": { "inputPerM": 2, "outputPerM": 10 } }; otherwise data/pricing.json
# is used if present. Falls back to the built-in table (see core/pricing.ts).
# ALFRED_PRICING_JSON=/path/to/pricing.json

# ─── Window ─────────────────────────────────────────────────────────────────────
# overlay (default): frameless transparent, always-on-top, click-through HUD —
# one per display; ⌘⇧A / ⌘⇧H toggle all of them. windowed: classic bordered
# window (fallback). Set ALFRED_SPAN_DISPLAYS=1 for a single overlay spanning the
# whole virtual desktop instead of one window per monitor.
ALFRED_WINDOW_MODE=overlay

# Auto-hide the top command/toolbar strip (macOS-menubar style; reveal on
# top-edge hover / ⌘K). On by default; set to 0 to keep it always visible.
# ALFRED_AUTOHIDE_TOP=1

# ─── Voice (macOS only) ─────────────────────────────────────────────────────────
# The voice defaults to Brazilian Portuguese (pt-BR). Voice output (Alfred speaks
# replies) is OFF by default — toggle it in the top bar. Two engines
# (ALFRED_TTS_ENGINE):
#
#   say (default) — macOS built-in `say`. Has pt-BR and many natural voices;
#     plays audio itself (no download).
#       ALFRED_TTS_VOICE  pt-BR: Luciana (♀, default) or Felipe (♂). If the voice
#                         isn't installed, Alfred retries once with the system
#                         default voice (never goes silent). `say -v '?'` lists
#                         installed voices. For much more natural output, download
#                         the "enhanced" / "premium" pt-BR voice in System Settings
#                         > Accessibility > Spoken Content > Manage Voices.
#       ALFRED_TTS_RATE   speaking rate in words/min (optional, e.g. 180).
#
#   kokoro — Kokoro TTS (kokoro-js, runs in Node, no Python). ENGLISH voices
#     only. ~300MB weights download lazily on the first spoken reply (or pre-warm
#     at setup with ALFRED_PREWARM_TTS=1).
#       ALFRED_TTS_VOICE  natural grade-A voices: af_heart, af_bella;
#                         male am_michael / am_puck / bm_george.
#       ALFRED_TTS_DTYPE  precision: q8 | q4 | fp16 | fp32 (default fp32).
#                         fp32 sounds LESS robotic; q8 is smaller/faster.
#
ALFRED_TTS_ENGINE=say
# Felipe (Enhanced) = pt-BR male, high-quality. Install it first: System Settings
# > Accessibility > Spoken Content > Manage Voices > Portuguese (Brazil) > Felipe
# (Enhanced). If it isn't installed, `say` falls back to the system voice.
ALFRED_TTS_VOICE="Felipe (Enhanced)"
# ALFRED_TTS_RATE=
# ALFRED_TTS_DTYPE=fp32
# Half-duplex tail: how long (ms) the mic stays muted after TTS stops speaking,
# so Alfred doesn't transcribe the end of its own voice. Default 700.
# ALFRED_TTS_TAIL_MS=700

# Voice input (push-to-talk, on-device SFSpeechRecognizer). Recognition language
# (default pt-BR) and the silence timeout in seconds that ends a session (default 2).
#
# NOTE: on-device recognition needs the language pack installed. The default
# pt-BR is NOT present on a factory Mac — add it in System Settings > Keyboard >
# Dictation > Edit > Português (Brasil). Without it Alfred falls back to SERVER
# recognition (needs internet); if neither works the helper reports it ONCE (no
# spam) and disables voice for that locale. Quick fix: ALFRED_STT_LOCALE=en-US.
ALFRED_STT_LOCALE=pt-BR
# ALFRED_STT_SILENCE=2.0
# Acoustic echo cancellation (macOS Voice Processing) on the mic input. ON by
# default — it cancels the speaker output (Alfred's own TTS) from the mic so you
# can say "Alfred" to interrupt him WHILE he's speaking (wake-word barge-in) and
# he stops hearing himself. If your audio hardware misbehaves with it, disable:
# ALFRED_STT_AEC=0
# NOTE: with echo cancellation OFF, barge-in only works with headphones (no
# speaker bleed into the mic).

# Wake word (always-on "Alfred", local, no account — reuses the STT helper in
# --wake mode; toggle 👂 WAKE in the top bar). Default trigger is "alfred" (also
# matches the ASR variant "alfredo"). Always-on recognition costs more CPU.
# ALFRED_WAKEWORD=alfred

# ── Prefer English instead? Override with these (pt-BR is the default above):
#   ALFRED_STT_LOCALE=en-US
#   ALFRED_TTS_ENGINE=kokoro
#   ALFRED_TTS_VOICE=af_heart

# ─── Gmail (read-only) ──────────────────────────────────────────────────────────
# Google OAuth client for Gmail (read-only). See README "Connecting Gmail".
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
