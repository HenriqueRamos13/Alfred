# ─── Brains / providers ───────────────────────────────────────────────────────
# Alfred can drive four brains. Set ALFRED_PROVIDER to pick the default; an API
# brain is "enabled" only when its API key is present. Model IDs below are
# defaults you can freely adjust to whatever your account has access to.

# Default brain: anthropic | openai | deepseek
ALFRED_PROVIDER=anthropic

# 1) Anthropic API (default active brain) — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-5

# 2) OpenAI / ChatGPT API — https://platform.openai.com/
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# 3) DeepSeek API — https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_MODEL=deepseek-v4-flash

# 4) Claude Code CLI (claude -p) — the delegation brain. No key here; install the
#    CLI so it's on PATH: npm i -g @anthropic-ai/claude-code

# Legacy alias for ANTHROPIC_MODEL (still honoured if ANTHROPIC_MODEL is unset).
ALFRED_MODEL=claude-sonnet-5

# ─── Workspace & guardrails ─────────────────────────────────────────────────────
# Where Alfred keeps projects & memory (defaults to ~/AlfredWorkspace)
ALFRED_WORKSPACE=

# Hard daily token cap across all sessions (kill-switch)
ALFRED_DAILY_TOKEN_BUDGET=2000000

# Soft daily USD warning (ESTIMATED cost). Warns when exceeded; never blocks —
# the hard stop is always ALFRED_DAILY_TOKEN_BUDGET above. Leave unset to disable.
# ALFRED_DAILY_USD_BUDGET=5

# Optional pricing override (USD per 1M tokens). Points at a JSON file shaped like
# { "model-id": { "inputPerM": 2, "outputPerM": 10 } }; otherwise data/pricing.json
# is used if present. Falls back to the built-in table (see core/pricing.ts).
# ALFRED_PRICING_JSON=/path/to/pricing.json

# ─── Window ─────────────────────────────────────────────────────────────────────
# overlay (default): frameless transparent HUD, always-on-top, covers the primary
# display; ⌘⇧A toggles it. windowed: classic bordered window (fallback).
ALFRED_WINDOW_MODE=overlay

# ─── Voice (macOS only) ─────────────────────────────────────────────────────────
# Voice output (Alfred speaks replies) is OFF by default — toggle it in the top
# bar. It uses the Kokoro TTS model (kokoro-js, runs in Node, no Python); the
# ~300MB weights download lazily on the first spoken reply (or pre-warm at setup
# with ALFRED_PREWARM_TTS=1). Override the voice (default af_heart):
# ALFRED_TTS_VOICE=af_heart

# Voice input (push-to-talk, on-device SFSpeechRecognizer). Recognition language
# (default en-US) and the silence timeout in seconds that ends a session (default 2):
# ALFRED_STT_LOCALE=en-US
# ALFRED_STT_SILENCE=2.0

# ─── Gmail (read-only) ──────────────────────────────────────────────────────────
# Google OAuth client for Gmail (read-only). See README "Connecting Gmail".
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
